# BharatIntel — Environment Variables
# Copy this to .env and fill in your API keys.
# NEVER commit .env to version control.

# ── News Source API Keys ─────────────────────────────────────────────
GNEWS_API_KEY=           # Free at https://gnews.io (100 req/day)

# ── LLM Provider Keys (set at least one) ─────────────────────────────
GEMINI_API_KEY=          # Google Gemini — https://aistudio.google.com (recommended, free tier)
OPENROUTER_API_KEY=      # OpenRouter — https://openrouter.ai (multi-model gateway)
XAI_API_KEY=             # xAI Grok — https://console.x.ai
GROQ_API_KEY=            # Groq — https://console.groq.com (fast inference)
OPENAI_API_KEY=          # OpenAI — https://platform.openai.com (optional)
ANTHROPIC_API_KEY=       # Anthropic Claude (optional)

# ── LLM Model Selection (litellm model strings) ─────────────────────
LLM_RANK_MODEL=gemini/gemini-2.5-flash     # Fast model for ranking
LLM_SUMMARY_MODEL=gemini/gemini-2.5-flash  # Quality model for summarization
